{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2020", "DOM"],

        "rootDir": "ts",
        "outDir": "js",

        "strict": true,
        "noEmitOnError": true,
        "sourceMap": true,
        "skipLibCheck": true
    },
    "include": ["ts/**/*.ts"]
}
